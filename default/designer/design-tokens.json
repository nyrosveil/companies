{
  "$schema": "https://design-tokens.org/schema/v1.json",
  "name": "Veil Corp - Paperclip Platform Design System",
  "version": "1.0.0",
  "date": "2026-03-20",
  "designer": "Jony Ive",
  "description": "Complete design token system for Paperclip Platform UI",
  "categories": {
    "color": {
      "primary": {
